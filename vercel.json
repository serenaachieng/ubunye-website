{
  "rewrites": [
    { "source": "/reports/:file", "destination": "/reports/:file" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/reports/:file",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    }
  ]
}
